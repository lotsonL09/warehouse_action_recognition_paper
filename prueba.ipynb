    "end_4=timer()\n",
    "\n",
    "print(end_4-end_3)\n",
    "\n",
    "video=video.permute(0,3,1,2) #frames,C,H,W\n",
    "\n",
    "if transform:\n",
    "    video=transform(video)\n",
    "\n",
    "end_5=timer()\n",
