    "index =0\n",
    "\n",
    "path = paths[index]\n",
    "\n",
    "label = labels[index]\n",
    "\n",
    "start = timer()\n",
    "\n",
    "video=VideoReader(str(path),ctx=cpu(0))\n",
    "\n",
    "end_1 = timer()\n",
    "\n",
    "print(end_1-start)\n",
    "\n",
    "total_frames = len(video)\n",
    "\n",
    "if strategy == \"motion-distribution\":\n",
    "    indices = range(len(video))\n",
    "else:\n",
    "    indices = sample_frames(total_frames)\n",
    "\n",
    "end_2=timer()\n",
    "\n",
    "print(end_2-end_1)\n",
    "\n",
    "video=video.get_batch(indices).asnumpy() # frames,H,W,C\n",
