    "model_name"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "28063b90",
   "metadata": {},
   "outputs": [],
   "source": [
    "targ_dir=dataset_dir/\"train\"\n",
    "\n",
    "paths=list(targ_dir.glob(\"*/*.mp4\"))\n",
    "\n",
    "idx_to_class,class_to_idx=find_classes(targ_dir)\n",
    "\n",
    "labels=[ class_to_idx[path.parent.name] for path in paths]\n",
    "\n",
    "transform = VideoTrainTransform(model=swin_model)\n",
    "\n",
    "strategy = \"uniform\"\n",
    "\n",
    "num_frames = 16"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "6c625373",
   "metadata": {},
   "outputs": [],
   "source": [
    "def sample_frames(total_frames):\n",
    "        \n",
    "        N=num_frames\n",
    "\n",
    "        if strategy == \"uniform\":\n",
    "            indices = np.linspace(0, total_frames - 1, N).astype(int)\n",
    "\n",
    "        elif strategy == \"random\":\n",
    "            if total_frames >= N:\n",
    "                indices = np.random.choice(total_frames, N, replace=False)\n",
    "                indices = np.sort(indices)\n",
    "            else:\n",
    "                indices = np.linspace(0, total_frames - 1, N).astype(int)\n",
    "        else:\n",
    "            raise ValueError(\"Unknown sampling strategy\")\n",
    "\n",
    "        return indices"
   ]
  },
